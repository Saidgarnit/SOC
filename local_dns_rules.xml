<group name="dns,">

  <!-- Base rule: any named query log line -->
  <rule id="100200" level="3">
    <if_sid>12100</if_sid>
    <match>queries: info: client</match>
    <description>DNS query logged by BIND</description>
    <group>dns,</group>
  </rule>

  <!-- Long subdomain — potential DNS tunneling/exfil -->
  <rule id="100201" level="10">
    <if_sid>100200</if_sid>
    <regex>client [\S]+ \([\w\.\-]{50,}\)</regex>
    <description>DNS exfiltration suspected: unusually long subdomain query</description>
    <mitre>
      <id>T1071.004</id>
    </mitre>
    <group>dns,exfiltration,</group>
  </rule>

  <!-- Known bad TLD patterns -->
  <rule id="100202" level="10">
    <if_sid>100200</if_sid>
    <match>\.exfil\.|\.c2\.|\.evil\.|\.dnscat\.</match>
    <description>DNS query to suspicious exfiltration domain</description>
    <mitre>
      <id>T1071.004</id>
    </mitre>
    <group>dns,exfiltration,c2,</group>
  </rule>

</group>
