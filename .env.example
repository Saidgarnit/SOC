## Core Elasticsearch/Kibana
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=REPLACE_ME
ES_JAVA_OPTS=-Xms1g -Xmx1g
ELASTICSEARCH_MEM_LIMIT=4g
KIBANA_MEM_LIMIT=1g
KIBANA_ENCRYPTION_KEY=REPLACE_WITH_32B_HEX
KIBANA_SERVICE_TOKEN=

## Logstash tuning
LOGSTASH_MEM_LIMIT=1g
LOGSTASH_PIPELINE_WORKERS=2
LOGSTASH_QUEUE_TYPE=persisted
LOGSTASH_QUEUE_MAX_BYTES=1gb
LOGSTASH_QUEUE_CHECKPOINT_WRITES=1024

## Wazuh
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=REPLACE_ME
WAZUH_MANAGER_MEM_LIMIT=1g

## OpenCTI
OPENCTI_ADMIN_EMAIL=admin@opencti.io
OPENCTI_ADMIN_PASSWORD=REPLACE_ME
OPENCTI_ADMIN_TOKEN=REPLACE_ME
OPENCTI_BASE_URL=http://localhost:3000
OPENCTI_MEM_LIMIT=512m

## RabbitMQ / MinIO (OpenCTI)
RABBITMQ_USER=REPLACE_ME
RABBITMQ_PASSWORD=REPLACE_ME
MINIO_ROOT_USER=REPLACE_ME
MINIO_ROOT_PASSWORD=REPLACE_ME

## MISP
MISP_API_KEY=RETRIEVE_FROM_MISP_UI
MISP_DB_ROOT_PASSWORD=REPLACE_ME
MISP_DB_PASSWORD=REPLACE_ME
MISP_DB_USER=misp
MISP_DB_NAME=misp
MISP_REDIS_PASSWORD=
MISP_BASE_URL=http://localhost:9001
MISP_MEM_LIMIT=2g
MISP_CONNECTOR_MEM_LIMIT=512m

## Threat Intel integrations
VIRUSTOTAL_API_KEY=REPLACE_ME
SLACK_WEBHOOK_URL=REPLACE_ME
SMTP_USER=REPLACE_ME
SMTP_PASSWORD=REPLACE_ME
SMTP_FROM=REPLACE_ME

## Fleet / Elastic Agent (lab)
FLEET_SERVER_ELASTICSEARCH_USERNAME=elastic
FLEET_SERVER_ELASTICSEARCH_PASSWORD=REPLACE_ME
FLEET_SERVER_SERVICE_TOKEN=REPLACE_ME
FLEET_SERVER_POLICY_ID=fleet-server-policy
FLEET_SERVER_HOST=127.0.0.1
ELASTIC_AGENT_ENROLLMENT_TOKEN=REPLACE_ME

## Optional TLS paths (generate and mount in ./certs)
ELASTIC_HTTP_SSL_ENABLED=false
ELASTIC_HTTP_SSL_CERT=/usr/share/elasticsearch/config/certs/http.crt
ELASTIC_HTTP_SSL_KEY=/usr/share/elasticsearch/config/certs/http.key
ELASTIC_HTTP_SSL_CA=/usr/share/elasticsearch/config/certs/ca.crt
KIBANA_SERVER_SSL_ENABLED=false
KIBANA_SERVER_SSL_CERT=/usr/share/kibana/config/certs/kibana.crt
KIBANA_SERVER_SSL_KEY=/usr/share/kibana/config/certs/kibana.key
