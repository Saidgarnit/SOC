# Core Elastic stack
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=change_me
ELASTICSEARCH_HOST=https://elasticsearch:9200

# Kibana
KIBANA_PUBLIC_URL=https://localhost:5601
KIBANA_ENCRYPTION_KEY=replace_with_32_chars
KIBANA_ENCRYPTEDSAVEDOBJECTS_KEY=replace_with_32_chars
KIBANA_REPORTING_KEY=replace_with_32_chars

# Fleet / Elastic Agent
FLEET_SERVER_SERVICE_TOKEN=replace_with_fleet_service_token
FLEET_ENROLLMENT_TOKEN=replace_with_fleet_enrollment_token
FLEET_SERVER_POLICY_ID=fleet-server-policy
FLEET_SERVER_HOST=0.0.0.0
FLEET_URL=https://fleet-server:8220

# OpenCTI
OPENCTI_ADMIN_EMAIL=admin@opencti.local
OPENCTI_ADMIN_PASSWORD=change_me
OPENCTI_ADMIN_TOKEN=replace_with_opencti_token
OPENCTI_BASE_URL=http://localhost:3000
OPENCTI_MINIO_ACCESS_KEY=opencti
OPENCTI_MINIO_SECRET_KEY=change_me
OPENCTI_RABBITMQ_USER=opencti
OPENCTI_RABBITMQ_PASSWORD=change_me

# MinIO (OpenCTI)
MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=change_me

# MISP
MISP_DB_ROOT_PASSWORD=change_me
MISP_DB_PASSWORD=change_me
MISP_REDIS_PASSWORD=change_me
MISP_ADMIN_EMAIL=admin@misp.local
MISP_ADMIN_PASSWORD=change_me
MISP_BASE_URL=http://localhost:9001
MISP_API_KEY=replace_with_misp_api_key
MISP_URL=http://misp

# Alerts / Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=alerts@example.com
SMTP_USER=alerts@example.com
SMTP_PASSWORD=change_me
SMTP_TO=security@example.com
SMTP_REPLY_TO=security@example.com

# Threat intelligence
VIRUSTOTAL_API_KEY=replace_with_vt_key

# Suricata
SURICATA_INTERFACE=eth0

# Victim services
FTP_USER=ftpuser
FTP_PASS=change_me
