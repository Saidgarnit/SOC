# nginx-proxy.conf - Clean version for docker nginx:alpine

server {
    listen 80;
    server_name _;

    # Redirect HTTP → HTTPS (optional - comment out if you don't have SSL yet)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name _;

    # === SSL Certificates (change paths if needed) ===
    ssl_certificate     /etc/nginx/certs/misp.crt;
    ssl_certificate_key /etc/nginx/certs/misp.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Buffers for large responses (useful for Kibana/OpenCTI)
    proxy_buffer_size 128k;
    proxy_buffers 4 256k;
    proxy_busy_buffers_size 256k;

    # ====================== MAIN PROXY LOCATIONS ======================

    # Root → redirect to Kibana or a dashboard page
    location / {
        proxy_pass http://kibana:5601;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
    }

    # OpenCTI
    location /opencti/ {
        proxy_pass http://opencti:3000/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Wazuh (if you expose the Wazuh dashboard later)
    # location /wazuh/ {
    #     proxy_pass http://wazuh-manager:5601/;   # adjust if needed
    #     ...
    # }

    # MISP - only enable when misp container is running
    # location /misp/ {
    #     proxy_pass http://misp:80/;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    #     proxy_cookie_path / /;
    #     proxy_cookie_flags ~ secure httponly samesite=lax;
    # }
}
