services:

  kali-attacker:
    image: kali-attacker-persistent:latest
    container_name: kali-attacker
    hostname: kali-attacker
    command: bash -c 'tail -f /dev/null'
    restart: unless-stopped
    cap_add:
      - NET_ADMIN
      - NET_RAW
    networks:
      soc-net:

  fleet-server:
    image: docker.elastic.co/elastic-agent/elastic-agent:8.13.0
    container_name: fleet-server
    hostname: fleet-server
    restart: unless-stopped
    user: root
    environment:
      - FLEET_SERVER_ENABLE=true
      - FLEET_SERVER_INSECURE_HTTP=true
      - FLEET_SERVER_HOST=0.0.0.0
      - FLEET_SERVER_PORT=8220
      - FLEET_SERVER_ELASTICSEARCH_HOST=http://elasticsearch:9200
      - FLEET_SERVER_ELASTICSEARCH_USERNAME=elastic
      - FLEET_SERVER_ELASTICSEARCH_PASSWORD=${ELASTIC_PASSWORD}
      - KIBANA_FLEET_HOST=http://kibana:5601
      - KIBANA_FLEET_USERNAME=elastic
      - KIBANA_FLEET_PASSWORD=${ELASTIC_PASSWORD}
    ports:
      - "8220:8220"
    networks:
      soc-net:
    depends_on:
      elasticsearch:
        condition: service_healthy

  victim-ubuntu:
    image: soc-stack-victim-ubuntu:latest
    container_name: victim-ubuntu
    hostname: victim-ubuntu
    restart: unless-stopped
    ports:
      - "2121:21"
      - "2222:22"
      - "8888:80"
    volumes:
      - yara-ubuntu-www:/var/www/html
      - yara-ubuntu-tmp:/tmp
      - soc-stack_elastic-agent-ubuntu:/opt/elastic-agent
    networks:
      soc-net:

  victim-dvwa:
    image: victim-dvwa-img:latest
    container_name: victim-dvwa
    hostname: victim-dvwa
    restart: unless-stopped
    ports:
      - "8890:80"
    volumes:
      - yara-dvwa:/var/www/html/dvwa
      - soc-stack_elastic-agent-dvwa:/opt/elastic-agent
    depends_on:
      - victim-database
    networks:
      soc-net:

  victim-windows:
    image: soc-stack-victim-windows:latest
    container_name: victim-windows
    hostname: victim-windows
    restart: unless-stopped
    ports:
      - "1390:139"
      - "4445:445"
    volumes:
      - soc-stack_elastic-agent-windows:/opt/elastic-agent
    networks:
      soc-net:

  victim-jenkins:
    image: soc-stack-victim-jenkins:latest
    container_name: victim-jenkins
    hostname: victim-jenkins
    restart: unless-stopped
    ports:
      - "9090:8080"
    volumes:
      - jenkins-home:/var/jenkins_home
      - soc-stack_elastic-agent-jenkins:/opt/elastic-agent
    networks:
      soc-net:

  victim-dns:
    image: soc-stack-victim-dns:latest
    container_name: victim-dns
    hostname: victim-dns
    restart: unless-stopped
    ports:
      - "53:53/tcp"
      - "53:53/udp"
    volumes:
      - soc-stack_elastic-agent-dns:/opt/elastic-agent
    networks:
      soc-net:

  victim-database:
    image: soc-stack-victim-database:latest
    container_name: victim-database
    hostname: victim-database
    restart: unless-stopped
    ports:
      - "3306:3306"
    volumes:
      - victim-db-data:/var/lib/mysql
      - soc-stack_elastic-agent-database:/opt/elastic-agent
    networks:
      soc-net:

  victim-mail:
    image: soc-stack-victim-mail:latest
    container_name: victim-mail
    hostname: victim-mail
    restart: unless-stopped
    ports:
      - "2525:25"
      - "1143:143"
    volumes:
      - soc-stack_elastic-agent-mail:/opt/elastic-agent
    networks:
      soc-net:

  victim-iot:
    image: soc-stack-victim-iot:latest
    container_name: victim-iot
    hostname: victim-iot
    restart: unless-stopped
    ports:
      - "1883:1883"
      - "8891:8080"
    volumes:
      - soc-stack_elastic-agent-iot:/opt/elastic-agent
    networks:
      soc-net:

  victim-metasploitable:
    image: soc-stack-victim-metasploitable:latest
    container_name: victim-metasploitable
    hostname: victim-metasploitable
    restart: unless-stopped
    ports:
      - "2122:21"
      - "2223:22"
      - "8889:80"
    networks:
      soc-net:

  victim-ftp:
    image: fauria/vsftpd
    container_name: victim-ftp
    hostname: victim-ftp
    restart: unless-stopped
    ports:
      - "2124:21"
      - "21100-21110:21100-21110"
    environment:
      - FTP_USER=ftp
      - FTP_PASS=ftp
      - PASV_MIN_PORT=21100
      - PASV_MAX_PORT=21110
    volumes:
      - yara-ftp:/home/vsftpd
      - elastic-agent-ftp:/opt/elastic-agent
      - wazuh_ossec_ftp:/var/ossec
    networks:
      soc-net:

  victim-webapi:
    image: raesene/bwapp
    container_name: victim-webapi
    hostname: victim-webapi
    restart: unless-stopped
    ports:
      - "8892:80"
    networks:
      soc-net:

volumes:
  jenkins-home:
  victim-db-data:
  yara-dvwa:
    external: true
  yara-ubuntu-www:
    external: true
  yara-ubuntu-tmp:
    external: true
  yara-ftp:
    external: true
  elastic-agent-ftp:
    external: true
  wazuh_ossec_ftp:
    external: true
  soc-stack_elastic-agent-ubuntu:
    external: true
  soc-stack_elastic-agent-dvwa:
    external: true
  soc-stack_elastic-agent-windows:
    external: true
  soc-stack_elastic-agent-jenkins:
    external: true
  soc-stack_elastic-agent-dns:
    external: true
  soc-stack_elastic-agent-database:
    external: true
  soc-stack_elastic-agent-mail:
    external: true
  soc-stack_elastic-agent-iot:
    external: true

networks:
  soc-net:
    external: true
