<!-- ============ AUTHENTICATION PROTECTION ============ -->

<!-- Multiple Login Failures (Rules 510, 511, 512) -->
<active-response>
  <command>firewall-drop</command>
  <location>local</location>
  <rules_id>510,511,512</rules_id>
  <timeout>3600</timeout>
</active-response>

<!-- Account Compromise - Disable User Account (Rules 5501, 5502) -->
<active-response>
  <command>disable-account</command>
  <location>local</location>
  <rules_id>5501,5502</rules_id>
  <timeout>3600</timeout>
</active-response>

<!-- ============ CRITICAL SEVERITY AUTO-BLOCK ============ -->

<!-- Any Event with Severity Level >= 12 -->
<active-response>
  <command>firewall-drop</command>
  <location>all</location>  <!-- Network-wide blocking -->
  <level>12</level>
  <timeout>3600</timeout>
</active-response>
